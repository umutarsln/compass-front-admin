# Backend API URL — Nest PORT ile uyumlu (ör. 4141)
NEXT_PUBLIC_API_URL=http://localhost:4141

# Storefront URL — relative hero görsellerinin admin önizlemesi için
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Cookie Names
NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_NAME=accessToken
NEXT_PUBLIC_REFRESH_TOKEN_COOKIE_NAME=refreshToken
